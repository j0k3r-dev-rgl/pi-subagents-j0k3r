{
  "name": "pi-subagents-j0k3r",
  "version": "1.0.0",
  "description": "Installable Pi package that adds markdown-defined subagents, delegated task tools, history, and model profiles.",
  "type": "module",
  "license": "MIT",
  "author": "j0k3r",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/j0k3r-dev-rgl/pi-subagents-j0k3r.git"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi",
    "subagents",
    "coding-agent",
    "agent",
    "delegation"
  ],
  "engines": {
    "node": ">=22.19.0"
  },
  "main": "./index.ts",
  "bin": {
    "subagents-terminal-viewer": "./bin/subagents-terminal-viewer.mjs"
  },
  "files": [
    "index.ts",
    "src",
    "bin",
    "skills",
    "scripts/verify-package-files.mjs",
    ".releaserc.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify:package": "node scripts/verify-package-files.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "check": "npm run typecheck && npm test && npm run verify:package",
    "release": "semantic-release",
    "prepublishOnly": "npm run check"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@semantic-release/github": "12.0.8",
    "@semantic-release/npm": "13.1.5",
    "@types/node": "24.10.1",
    "semantic-release": "25.0.5",
    "typebox": "1.1.38",
    "typescript": "5.9.3",
    "vitest": "4.1.7"
  }
}
